{
	"name": "decree-ui",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"preview": "vite preview",
		"lint": "biome check src/",
		"format": "biome format --write src/",
		"typecheck": "tsc -b --noEmit",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"generate": "swagger2openapi openapi.json -o openapi3.json && openapi-typescript openapi3.json -o src/api/schema.d.ts",
		"screenshots": "tsx scripts/screenshots.ts",
		"pre-commit": "biome check src/ && tsc -b --noEmit && vitest run && npm run build"
	},
	"dependencies": {
		"@tanstack/react-query": "^5.99.0",
		"openapi-fetch": "^0.17.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-router-dom": "^7.14.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.11",
		"@playwright/test": "^1.59.1",
		"@tailwindcss/vite": "^4.2.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^24.12.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/coverage-v8": "^4.1.4",
		"jsdom": "^29.0.2",
		"openapi-typescript": "^7.13.0",
		"swagger2openapi": "^7.0.8",
		"tailwindcss": "^4.2.2",
		"tsx": "^4.21.0",
		"typescript": "~5.8.0",
		"vite": "^8.0.4",
		"vitest": "^4.1.4"
	}
}
